{
  "manifest_version": 3,
  "name": "Claude Voyager",
  "version": "0.1.0",
  "description": "为 claude.ai 网页端增加右侧时间轴导航、对话整理与按钮中文化的增强插件。",
  "default_locale": "zh_CN",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_popup": "src/popup/popup.html",
    "default_title": "Claude Voyager 设置",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png"
    }
  },
  "permissions": ["storage"],
  "host_permissions": ["https://claude.ai/*"],
  "content_scripts": [
    {
      "matches": ["https://claude.ai/*"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle",
      "all_frames": false
    },
    {
      "matches": ["https://claude.ai/*"],
      "js": ["bridge.js"],
      "run_at": "document_idle",
      "world": "MAIN",
      "all_frames": false
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["icons/*"],
      "matches": ["https://claude.ai/*"]
    }
  ]
}
